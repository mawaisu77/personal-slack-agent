# Copy to `.env` for local development. Never commit real secrets.

# --- Database (sync URL for Alembic; use psycopg3 driver) ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personal_ai

# --- Redis (T-004) ---
REDIS_URL=redis://localhost:6379/0

# --- Playwright (T-017) ---
# PLAYWRIGHT_USER_DATA_DIR=.playwright-profile

# --- Voice (T-028) ---
# VOICE_PROVIDER=noop

# --- Secrets (T-010) ---
# `env` = read secrets from process environment variables by name (below).
# `aws` = load a JSON bundle from AWS Secrets Manager (production).
SECRETS_MODE=env
# AWS_REGION=
# AWS_APP_SECRET_ID=

# Optional: required only when SECRETS_MODE=aws
# Example names your app will request via get_secret("SLACK_BOT_TOKEN"):
# SLACK_BOT_TOKEN=
# ANTHROPIC_API_KEY=

# --- Slack (T-016) — use get_secret(...) for both ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# --- Logging ---
# Set to `json` for structured JSON logs (grep by task_id / user_id).
# LOG_FORMAT=json

# --- Runtime ---
ENVIRONMENT=dev
